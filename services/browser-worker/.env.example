APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
LOCAL_PROFILE_ROOT=.local_profiles
LOCAL_SCREENSHOT_ROOT=.local_screenshots
LOCAL_DOWNLOAD_ROOT=.local_downloads
YINGDAO_API_BASE_URL=https://api.winrobot360.com
YINGDAO_ACCESS_KEY_ID=change_me
YINGDAO_ACCESS_KEY_SECRET=change_me
YINGDAO_ACCOUNT_NAME=change_me
YINGDAO_ROBOT_UUID=change_me
YINGDAO_JOB_POLL_INTERVAL_SECONDS=3
YINGDAO_JOB_TIMEOUT_SECONDS=600

# Yingdao local file handoff
YINGDAO_LOCAL_HANDOFF_ENABLED=true
YINGDAO_LOCAL_QUEUE_ROOT=.local_rpa_queue/yingdao
YINGDAO_SEARCH_ACTIVE_JOB_PATH=.local_rpa_queue/yingdao/search/_active_job.json
YINGDAO_PUBLISH_ACTIVE_JOB_PATH=.local_rpa_queue/yingdao/publish/_active_publish_job.json
YINGDAO_LOCAL_HANDOFF_SAFE_MODE=true

# Still disabled for real API
YINGDAO_ENABLE_REAL_API=false

# Yingdao desktop manual smoke
YINGDAO_DESKTOP_SMOKE_ENABLED=true
YINGDAO_DESKTOP_SMOKE_ALLOW_MOCK_WRITE=true
YINGDAO_DESKTOP_SMOKE_OPEN_BROWSER=false
YINGDAO_DESKTOP_SMOKE_OPEN_XHS=false

# Yingdao browserless form-fill simulator
YINGDAO_FORM_SIMULATOR_ENABLED=true
YINGDAO_FORM_SIMULATOR_ALLOW_MOCK_WRITE=true
YINGDAO_FORM_SIMULATOR_OPEN_BROWSER=false
YINGDAO_FORM_SIMULATOR_OPEN_XHS=false
YINGDAO_FORM_SIMULATOR_ALLOW_REAL_ACTIONS=false

# Yingdao local HTML sandbox
YINGDAO_HTML_SANDBOX_ENABLED=true
YINGDAO_HTML_SANDBOX_ALLOW_OPEN_LOCAL_FILE=true
YINGDAO_HTML_SANDBOX_ALLOW_MOCK_WRITE=true
YINGDAO_HTML_SANDBOX_ALLOW_EXTERNAL_URL=false
YINGDAO_HTML_SANDBOX_ALLOW_XHS_URL=false
YINGDAO_HTML_SANDBOX_ALLOW_REAL_ACTIONS=false

# Yingdao selector mapping report
YINGDAO_SELECTOR_MAPPING_ENABLED=true
YINGDAO_SELECTOR_MAPPING_ALLOW_MOCK_CONFIRM=true
YINGDAO_SELECTOR_MAPPING_ALLOW_EXTERNAL_URL=false
YINGDAO_SELECTOR_MAPPING_ALLOW_XHS_URL=false
YINGDAO_SELECTOR_MAPPING_ALLOW_REAL_ACTIONS=false

# Yingdao actual local form-fill smoke
YINGDAO_ACTUAL_FORM_FILL_ENABLED=true
YINGDAO_ACTUAL_FORM_FILL_ALLOW_OPEN_LOCAL_HTML=true
YINGDAO_ACTUAL_FORM_FILL_ALLOW_MOCK_WRITE=true
YINGDAO_ACTUAL_FORM_FILL_ALLOW_EXTERNAL_URL=false
YINGDAO_ACTUAL_FORM_FILL_ALLOW_XHS_URL=false
YINGDAO_ACTUAL_FORM_FILL_ALLOW_REAL_ACTIONS=false

# XHS account binding check
XHS_ACCOUNT_BINDING_ENABLED=true
XHS_ACCOUNT_BINDING_ALLOW_MOCK_CONFIRM=true
XHS_ACCOUNT_BINDING_PROFILE_MAP_PATH=.config/kuaijingvs_profiles.json
XHS_ACCOUNT_BINDING_REQUIRE_DISCOVERY_EVIDENCE=false
XHS_ACCOUNT_BINDING_ALLOW_KJVS_OPEN_SHOP=false
XHS_ACCOUNT_BINDING_ALLOW_XHS_URL=false
XHS_ACCOUNT_BINDING_ALLOW_REAL_ACTIONS=false

# KuaJingVS discovery evidence hardening
KJVS_DISCOVERY_HARDENING_ENABLED=true
KJVS_DISCOVERY_SOURCE_PATH=.local_evidence/kuaijingvs_discovery/discovery.json
KJVS_DISCOVERY_HARDENED_PATH=.local_evidence/kuaijingvs_discovery/hardened_discovery.json
KJVS_DISCOVERY_HARDENED_SUMMARY_PATH=.local_evidence/kuaijingvs_discovery/hardened_discovery_summary.json
KJVS_DISCOVERY_FAIL_ON_SENSITIVE_VALUE=true

# Account binding strict mode
XHS_ACCOUNT_BINDING_STRICT_MODE_ENABLED=true
XHS_ACCOUNT_BINDING_REQUIRE_HARDENED_DISCOVERY=true
XHS_ACCOUNT_BINDING_FAIL_ON_SHOP_UNMATCHED=true
XHS_ACCOUNT_BINDING_FAIL_ON_SHOP_NAME_MISMATCH=true
XHS_ACCOUNT_BINDING_FAIL_ON_PROVIDER_TYPE_INVALID=true
XHS_ACCOUNT_BINDING_FAIL_ON_DISCOVERY_UNSAFE=true

# Local contract replay
XHS_LOCAL_CONTRACT_REPLAY_ENABLED=true
XHS_LOCAL_CONTRACT_REPLAY_ALLOW_N8N_MOCK=true
XHS_LOCAL_CONTRACT_REPLAY_ALLOW_OPENCLAW_MOCK=true
XHS_LOCAL_CONTRACT_REPLAY_ALLOW_EXTERNAL_N8N=false
XHS_LOCAL_CONTRACT_REPLAY_ALLOW_EXTERNAL_OPENCLAW=false
XHS_LOCAL_CONTRACT_REPLAY_REQUIRE_STRICT_BINDING=true
XHS_LOCAL_CONTRACT_REPLAY_REQUIRE_HARDENED_DISCOVERY=true
XHS_LOCAL_CONTRACT_REPLAY_FAIL_ON_SENSITIVE_PAYLOAD=true

# Local Feishu/PostgreSQL/MinIO mock persistence replay
XHS_LOCAL_PERSISTENCE_REPLAY_ENABLED=true
XHS_LOCAL_PERSISTENCE_REPLAY_REQUIRE_CONTRACT_REPLAY=true
XHS_LOCAL_PERSISTENCE_REPLAY_REQUIRE_STRICT_BINDING=true
XHS_LOCAL_PERSISTENCE_REPLAY_REQUIRE_HARDENED_DISCOVERY=true
XHS_LOCAL_PERSISTENCE_REPLAY_FAIL_ON_SENSITIVE_PAYLOAD=true
XHS_LOCAL_PERSISTENCE_ALLOW_FEISHU_MOCK=true
XHS_LOCAL_PERSISTENCE_ALLOW_POSTGRES_MOCK=true
XHS_LOCAL_PERSISTENCE_ALLOW_MINIO_MOCK=true
XHS_LOCAL_PERSISTENCE_ALLOW_REAL_FEISHU=false
XHS_LOCAL_PERSISTENCE_ALLOW_REAL_POSTGRES=false
XHS_LOCAL_PERSISTENCE_ALLOW_REAL_MINIO=false

# Controlled PostgreSQL persistence from local replay payloads
POSTGRES_DSN=postgresql://xhs_user:change_me@127.0.0.1:5432/xhs_automation
XHS_POSTGRES_PERSISTENCE_ENABLED=false
XHS_ALLOW_REAL_POSTGRES_WRITE=false
XHS_POSTGRES_PERSISTENCE_DRY_RUN=true
XHS_POSTGRES_SCHEMA_PATH=database/xhs_persistence_schema.sql
XHS_POSTGRES_FAIL_ON_SENSITIVE_PAYLOAD=true

# Local full E2E replay orchestrator
XHS_LOCAL_E2E_REPLAY_ENABLED=true
XHS_LOCAL_E2E_REPLAY_REQUIRE_READINESS=true
XHS_LOCAL_E2E_REPLAY_REQUIRE_STRICT_BINDING=true
XHS_LOCAL_E2E_REPLAY_REQUIRE_HARDENED_DISCOVERY=true
XHS_LOCAL_E2E_REPLAY_REQUIRE_CONTRACT_REPLAY=true
XHS_LOCAL_E2E_REPLAY_REQUIRE_PERSISTENCE_REPLAY=true
XHS_LOCAL_E2E_REPLAY_FAIL_ON_SENSITIVE_PAYLOAD=true
XHS_LOCAL_E2E_REPLAY_ALLOW_EXTERNAL_CALLS=false

KJVS_API_BASE_URL=http://127.0.0.1:49709
KJVS_API_ID=change_me
KJVS_API_SECRET=change_me
KJVS_PROFILE_MAP_PATH=.config/kuaijingvs_profiles.json
KJVS_ENV_READY_TIMEOUT_SECONDS=60
KJVS_ENV_POLL_INTERVAL_SECONDS=3
RPA_LOCAL_QUEUE_ROOT=.local_rpa_jobs
RPA_LOCAL_EVIDENCE_ROOT=.local_evidence
RPA_LOCAL_EVIDENCE_TIMEOUT_SECONDS=300
RPA_WRITE_EVIDENCE_SCRIPT_PATH=scripts/write_yingdao_smoke_evidence.ps1

# External readiness / integration mode
XHS_EXTERNAL_READINESS_MODE=dry_run
XHS_ALLOW_LIVE_READONLY_CHECKS=false
XHS_ALLOW_LIVE_WRITE_ACTIONS=false

# n8n
N8N_BASE_URL=http://127.0.0.1:5678
N8N_XHS_SEARCH_WEBHOOK_PATH=/webhook/xhs/search
N8N_XHS_PUBLISH_WEBHOOK_PATH=/webhook/xhs/publish

# OpenClaw
OPENCLAW_BASE_URL=http://127.0.0.1:3000
OPENCLAW_XHS_JOB_STATUS_PATH=/api/xhs/job-status

# Feishu
FEISHU_APP_ID=change_me
FEISHU_APP_SECRET=change_me
FEISHU_XHS_WORKFLOW_TABLE_ID=change_me

# PostgreSQL
# POSTGRES_DSN is defined above for controlled PostgreSQL persistence.

# MinIO
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=xhs-assets
